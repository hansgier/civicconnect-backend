generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  BARANGAY
  ASSISTANT_ADMIN
  CITIZEN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum ProjectStatus {
  ONGOING
  COMPLETED
  CANCELLED
  ON_HOLD
  PLANNED
  APPROVED_PROPOSAL
}

enum ProjectCategory {
  INSTITUTIONAL
  TRANSPORTATION
  HEALTH
  WATER
  EDUCATION
  SOCIAL
  INFRASTRUCTURE
  SPORTS_AND_RECREATION
  ECONOMIC
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum AnnouncementCategory {
  EVENT
  SAFETY
  POLICY
  INFRASTRUCTURE
}

enum NotificationType {
  APPROVAL
  COMMENT
  UPDATE
  ANNOUNCEMENT
  SYSTEM
}

enum ContactType {
  EMERGENCY
  GOVERNMENT
  HEALTH
  EDUCATION
  ENVIRONMENT
  BUSINESS
  WATER
  ELECTRICITY
}

model User {
  id                    String     @id @default(uuid())
  name                  String
  email                 String     @unique
  password              String?
  role                  UserRole   @default(CITIZEN)
  status                UserStatus @default(PENDING)
  emailVerified         Boolean    @default(false)
  verificationToken     String?
  verificationTokenExp  DateTime?
  passwordResetToken    String?
  passwordResetTokenExp DateTime?
  refreshToken          String?
  barangayId            String?
  googleId              String?    @unique
  facebookId            String?    @unique
  avatar                String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  barangay       Barangay?       @relation(fields: [barangayId], references: [id], onDelete: SetNull)
  projects       Project[]
  comments       Comment[]
  reactions      Reaction[]
  announcements  Announcement[]
  contacts       Contact[]
  notifications  Notification[]

  @@map("users")
}

model Barangay {
  id         String   @id @default(uuid())
  name       String   @unique
  district   String?
  population Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users    User[]
  projects ProjectBarangay[]

  @@map("barangays")
}

model Project {
  id                  String           @id @default(uuid())
  title               String           @unique
  description         String?          @db.Text
  cost                Decimal?         @db.Decimal(15, 2)
  startDate           DateTime?
  dueDate             DateTime?
  completionDate      DateTime?
  status              ProjectStatus    @default(PLANNED)
  category            ProjectCategory?
  implementingAgency  String?
  contractor          String?
  createdById         String
  fundingSourceId     String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  createdBy     User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  fundingSource FundingSource?  @relation(fields: [fundingSourceId], references: [id], onDelete: SetNull)
  barangays     ProjectBarangay[]
  comments      Comment[]
  media         Media[]
  updates       ProjectUpdate[]
  reactions     Reaction[]
  notifications Notification[]

  @@map("projects")
}

model ProjectBarangay {
  projectId  String
  barangayId String

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  barangay Barangay @relation(fields: [barangayId], references: [id], onDelete: Cascade)

  @@id([projectId, barangayId])
  @@map("project_barangays")
}

model ProjectUpdate {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  date        DateTime @default(now())
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_updates")
}

model Comment {
  id         String    @id @default(uuid())
  content    String    @db.Text
  userId     String
  projectId  String
  parentId   String?                    // NEW: self-referential FK for replies
  isOfficial Boolean   @default(false)  // NEW: marks official responses
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")
  reactions Reaction[]

  @@map("comments")
}

model Reaction {
  id        String       @id @default(uuid())
  type      ReactionType
  userId    String
  projectId String?
  commentId String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@unique([userId, commentId])
  @@map("reactions")
}

model Media {
  id              String    @id @default(uuid())
  url             String
  publicId        String    @unique
  type            MediaType @default(IMAGE)
  projectId       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("media")
}

model FundingSource {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]

  @@map("funding_sources")
}

model Notification {
  id             String           @id @default(uuid())
  title          String
  description    String           @db.Text
  type           NotificationType
  read           Boolean          @default(false)
  userId         String
  projectId      String?
  announcementId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  announcement Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Announcement {
  id        String                @id @default(uuid())
  title     String
  content   String                @db.Text
  excerpt   String?               // NEW
  image     String?               // NEW: URL string
  category  AnnouncementCategory? // NEW
  isUrgent  Boolean               @default(false) // NEW
  location  String?               // NEW
  authorId  String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  notifications Notification[] // NEW — reverse relation

  @@map("announcements")
}

model Contact {
  id           String      @id @default(uuid())
  title        String
  description  String?     @db.Text
  phoneNumbers String[]
  primaryPhone String?
  emails       String[]
  schedule     String?
  location     String?
  type         ContactType
  isEmergency  Boolean     @default(false)
  order        Int?
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("contacts")
}
